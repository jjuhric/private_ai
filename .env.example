# Port to run the application (defaults to 3000)
PORT=3000

# Secret key for JWT session tokens
JWT_SECRET=some_long_random_secret_phrase_for_private_ai_assistant

# SQLite Database path (defaults to backend/database.db)
DB_PATH=backend/database.db

# Use 'backend-only' if deploying to a field node that doesn't build the React frontend
# DEPLOY_MODE=backend-only

# Local LLM Connection & Credentials baseline
LOCAL_LLM_URL=http://localhost:1234/v1
LOCAL_LLM_KEY=

# Online Model API Keys
GEMINI_API_KEY=
GITHUB_TOKEN=

# Model Baselines (used as defaults if database preferences are empty)
PREFERRED_LOCAL_MODEL=qwen/qwen3.5-9b
PREFERRED_ONLINE_MODEL=gemini-2.0-flash
SUPERVISOR_MODEL=gemini-1.5-pro

# MQTT Broker Configuration
MQTT_BROKER_URL=mqtt://localhost:1883
MQTT_NODE_ID=windows-main
MQTT_USERNAME=
MQTT_PASSWORD=

# Tool Registry Configuration
TOOL_REGISTRY_REPO=https://github.com/jjuhric/private_ai_tools.git
TOOL_REGISTRY_LOCAL_PATH=./tool_registry
