# Port to run the application (use 5173 for Raspberry Pi 5 deployment)
PORT=5173

# Secret key for JWT session tokens
JWT_SECRET=some_long_random_secret_phrase_for_private_ai_assistant

# SQLite Database path (defaults to backend/database.db)
DB_PATH=backend/database.db

# Use 'backend-only' if deploying to a field node that doesn't build the React frontend
# DEPLOY_MODE=backend-only
