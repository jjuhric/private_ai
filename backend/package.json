{
  "name": "private-ai-backend",
  "version": "5.2.0",
  "private": true,
  "main": "server.js",
  "jest": {
    "coverageThreshold": {
      "global": {
        "statements": 70,
        "lines": 70
      }
    },
    "testPathIgnorePatterns": [
      "/node_modules/",
      "([\\\\/]|^)test\\.js$"
    ]
  },
  "dependencies": {
    "@google/generative-ai": "^0.24.1",
    "@xenova/transformers": "^2.0.1",
    "axios": "^1.18.1",
    "bcryptjs": "^2.4.3",
    "cheerio": "^1.2.0",
    "chromecast-api": "^0.4.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-rate-limit": "^8.5.2",
    "google-assistant": "^0.7.0",
    "google-news-url-decoder": "^1.2.2",
    "jsonwebtoken": "^9.0.2",
    "mqtt": "^5.14.0",
    "node-dns-sd": "^1.0.1",
    "node-html-parser": "^8.0.4",
    "sqlite": "^5.1.1",
    "sqlite3": "^6.0.1",
    "ssh2": "^1.17.0",
    "@lancedb/lancedb": "^0.4.2",
    "winston": "^3.19.0",
    "ws": "^8.21.0"
  },
  "scripts": {
    "test": "jest --runInBand --forceExit",
    "test:coverage": "jest --coverage --runInBand --forceExit"
  },
  "devDependencies": {
    "jest": "^29.7.0",
    "supertest": "^7.0.0"
  },
  "overrides": {
    "protobufjs": "^7.6.5",
    "xml2js": "^0.6.2"
  },
  "engines": {
    "node": ">=22.0.0"
  }
}
